{
  "name": "@pushkind/frontend-shell",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx}\" \"frontend/tsconfig.json\"",
    "format:check": "prettier --check \"frontend/src/**/*.{ts,tsx}\" \"frontend/tsconfig.json\"",
    "lint": "tsc -p frontend/tsconfig.json --noEmit",
    "test": "vitest run frontend/src",
    "typecheck": "tsc -p frontend/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "marked": "^18.0.2"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "files": [
    "frontend",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./frontend/src/index.ts",
      "default": "./frontend/src/index.ts"
    },
    "./DropdownMultiSelect": {
      "types": "./frontend/src/DropdownMultiSelect.tsx",
      "default": "./frontend/src/DropdownMultiSelect.tsx"
    },
    "./UserMenuDropdown": {
      "types": "./frontend/src/UserMenuDropdown.tsx",
      "default": "./frontend/src/UserMenuDropdown.tsx"
    },
    "./ServiceNavbar": {
      "types": "./frontend/src/ServiceNavbar.tsx",
      "default": "./frontend/src/ServiceNavbar.tsx"
    },
    "./ModalFlashShell": {
      "types": "./frontend/src/ModalFlashShell.tsx",
      "default": "./frontend/src/ModalFlashShell.tsx"
    },
    "./ShellFatalState": {
      "types": "./frontend/src/ShellFatalState.tsx",
      "default": "./frontend/src/ShellFatalState.tsx"
    },
    "./shellApi": {
      "types": "./frontend/src/shellApi.ts",
      "default": "./frontend/src/shellApi.ts"
    },
    "./json": {
      "types": "./frontend/src/json.ts",
      "default": "./frontend/src/json.ts"
    },
    "./useServiceShell": {
      "types": "./frontend/src/useServiceShell.ts",
      "default": "./frontend/src/useServiceShell.ts"
    },
    "./noAccess": {
      "types": "./frontend/src/noAccess.tsx",
      "default": "./frontend/src/noAccess.tsx"
    },
    "./mutations": {
      "types": "./frontend/src/mutations.ts",
      "default": "./frontend/src/mutations.ts"
    },
    "./markdown": {
      "types": "./frontend/src/markdown.tsx",
      "default": "./frontend/src/markdown.tsx"
    },
    "./types": {
      "types": "./frontend/src/types.ts",
      "default": "./frontend/src/types.ts"
    }
  }
}
